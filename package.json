{
  "name": "puddle-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-perms.mjs",
    "build": "pnpm --filter @puddle/shared build && pnpm --filter @puddle/web build && pnpm --filter @puddle/daemon build && pnpm --filter @puddle-code/cli build",
    "typecheck": "tsc -b packages/shared packages/daemon packages/cli && pnpm --filter @puddle/web typecheck",
    "test": "vitest run",
    "lint": "eslint . && prettier --check . && pnpm --filter @puddle/web check-tokens",
    "format": "prettier --write .",
    "dev": "pnpm --parallel --filter @puddle/daemon --filter @puddle/web dev",
    "build:tarball": "node scripts/build-tarball.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.25.12",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
